{
  "expo": {
    "name": "Illvoice",
    "slug": "Illvoice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "illvoice",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "config": {
        "googleMapsApiKey": "AIzaSyASTc0FN3JBdR8cmUb51CbuwQlNgl1Y5m0"
      },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karinobrutal.Illvoice",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.karinobrutal.Illvoice",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyASTc0FN3JBdR8cmUb51CbuwQlNgl1Y5m0"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.801122004565-uqv7spn6omlanheqo7e3n8e8pn30nbdo"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ], 
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to photos to attach evidence.",
          "cameraPermission": "Allow camera to take evidence photos."
        }
      ],
      [
        "react-native-maps",
        {
          "mapsVersion": "google-play-services-maps@18.2.0",
          "apiKey": "AIzaSyASTc0FN3JBdR8cmUb51CbuwQlNgl1Y5m0"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d6f4435b-2dbd-449e-ae17-c7c87d14a711"
      }
    }
  }
}